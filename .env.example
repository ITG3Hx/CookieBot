# CookieBot environment - copy to .env for local runs, or set these on Railway.

# core (required)
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
OWNER_ID=

# web control panel
# password for /dashboard - if unset, a random one is generated and printed to the console on boot
DASHBOARD_PASSWORD=

# channels
APPLICATION_CHANNEL_ID=
LOG_CHANNEL_ID=
MODLOG_CHANNEL_ID=

# tester linking (defaults exist in testers.js)
TESTING_CHANNEL_ID=
ROLE_TESTER=
ROLE_SR_TESTER=
TESTER_API_SECRET=

# giveaways (optional)
GIVEAWAY_REWARD_ROLE_ID=
GIVEAWAY_EMOJI=
GIVEAWAY_COLOR=

# server
PORT=3000
